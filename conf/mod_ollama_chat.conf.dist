[worldserver]

########################################
# mod-ollama-chat configuration
########################################

# --------------------------------------------
# CORE MODULE TOGGLES & DEBUGGING
# --------------------------------------------

# OllamaChat.Enable
#     Description: Enable or disable the module.
#     Default:     1 (true)
OllamaChat.Enable = 1

# OllamaChat.DebugEnabled
#     Description: Enables extra logging for debugging purposes.
#                  When set to 1 (true), detailed debug information will be logged by the module.
#                  When set to 0 (false), only standard logging is used.
#     Default:     0 (false)
OllamaChat.DebugEnabled = 0

# OllamaChat.DebugShowFullPrompt

#     Description: When enabled (1), logs the complete prompt sent to the Ollama API including RAG information.
#                  This is useful for debugging what information the RAG system provides to bots.
#                  Only active when OllamaChat.DebugEnabled is also enabled.
#                  When disabled (0), only standard logging is used.
#     Default:     0 (false)
OllamaChat.DebugShowFullPrompt = 0

# --------------------------------------------
# OLLAMA LLM CONNECTION AND INFERENCE
# --------------------------------------------

# OllamaChat.Url
#     Description: The URL used to query the Ollama API.
#     Default:     http://localhost:11434/api/generate
OllamaChat.Url = http://localhost:11434/api/generate

# OllamaChat.Model
#     Description: The model identifier to be used in the Ollama API request.
#     Default:     llama3.2:1b
OllamaChat.Model = llama3.2:1b

# OllamaChat.NumPredict
#     Description: Maximum number of tokens to generate in Ollama responses.
#     0 = unlimited. Only set if you want a hard cap.
#     Default: 40
#
#     | NumPredict | Approx. Words | Use Case                         |
#     |:----------:|:-------------:|:---------------------------------|
#     |     20     |   ~13–15      | Very short/emote/chat            |
#     |     30     |     ~20       | Short reply                      |
#     |     40     |   ~27–30      | Standard WoW reply (recommended) |
#     |     50     |   ~35–38      | Slightly longer reply            |
#     |     75     |   ~50–60      | Long quest/lore text             |
#     |    100+    |   70–80+      | Multi-paragraph (not typical)    |
OllamaChat.NumPredict = 100

# OllamaChat.SoftStopEnable
#     When enabled (1), the Ollama request streams and stops at the first complete-sentence
#     boundary once NumPredict tokens have been generated, so replies end on a finished sentence
#     instead of being cut mid-word. NumPredict is the soft target (small token headroom past it to
#     finish the sentence). No effect when NumPredict = 0 or ThinkModeEnableForModule = 1. 0 = legacy non-streaming.
#     Default: 1
OllamaChat.SoftStopEnable = 1

# OllamaChat.Temperature
#     Description: Controls the "creativity" or randomness of the model’s output.
#                  Lower values (e.g., 0.2) = more focused, repetitive, and predictable.
#                  Higher values (e.g., 1.0) = more random, creative, or surprising.
#                  0.8 is the Ollama default.
#     Example:     OllamaChat.Temperature = 0.6
#     Default:     0.8
OllamaChat.Temperature = 0.8

# OllamaChat.TopP
#     Description: Controls nucleus sampling, another way to shape randomness.
#                  Lower values (e.g., 0.5) = more conservative.
#                  Higher values (up to 1.0) = more open.
#                  0.95 is the Ollama default.
#     Example:     OllamaChat.TopP = 0.9
#     Default:     0.95
OllamaChat.TopP = 0.95

# OllamaChat.RepeatPenalty
#     Description: Discourages repetition in model output.
#                  1.0 = no penalty. Higher (e.g., 1.2) = less repetition.
#                  1.1 is the Ollama default.
#     Example:     OllamaChat.RepeatPenalty = 1.2
#     Default:     1.1
OllamaChat.RepeatPenalty = 1.1

# OllamaChat.TopK
#     Description: Limits sampling to the top K most likely tokens. Higher = more diverse.
#                  0 = unset (uses the model default, typically 40). Typical: 40.
#     Example:     OllamaChat.TopK = 40
#     Default:     0
OllamaChat.TopK = 0

# OllamaChat.MinP
#     Description: Min-p sampling: keep tokens with probability >= MinP * (top token prob).
#                  An alternative to TopP. 0.0 = unset (model default). Typical: 0.05.
#     Example:     OllamaChat.MinP = 0.05
#     Default:     0.0
OllamaChat.MinP = 0.0

# OllamaChat.PresencePenalty
#     Description: Penalizes tokens that have already appeared, encouraging new topics.
#                  0.0 = unset (model default / no penalty). Typical: 0.1-0.5.
#     Example:     OllamaChat.PresencePenalty = 0.2
#     Default:     0.0
OllamaChat.PresencePenalty = 0.0

# OllamaChat.FrequencyPenalty
#     Description: Penalizes tokens proportionally to how often they have appeared,
#                  reducing repetition. 0.0 = unset (model default / no penalty). Typical: 0.1-0.5.
#     Example:     OllamaChat.FrequencyPenalty = 0.2
#     Default:     0.0
OllamaChat.FrequencyPenalty = 0.0

# OllamaChat.NumCtx
#     Description: Maximum context length (in tokens) sent to the model.
#                  0 = model default. Use a value only if you want to restrict or expand context.
#                  Example for Llama-3 8B: 8192. For 70B: 8192/32768.
#     Example:     OllamaChat.NumCtx = 4096
#     Default:     0
OllamaChat.NumCtx = 0

# OllamaChat.NumThreads
#     Description: Maximum number of threads the model should use to compute the request.
#                  0 = model default. Use a value only if you want to restrict or change from auto.
#                  
#     Example:     OllamaChat.NumThreads = 2
#     Default:     0
OllamaChat.NumThreads = 0

# OllamaChat.Stop
#     Description: Optional. Comma-separated list of string "stop sequences". If the model outputs any of these strings, it will immediately stop generating further text and return the response up to that point. Use this to prevent the model from continuing into unwanted sections, such as another user's dialogue turn in a chat application.
#                  Example: "User:,Bot:" will stop the output if "User:" or "Bot:" appears in the response. Leave blank to disable.
#     Example:     OllamaChat.Stop = User:,Bot:
#     Default:     (empty)
OllamaChat.Stop =

# OllamaChat.SystemPrompt
#     Description: Optional. Content for the "system" field sent to Ollama. Can be used to steer or "prime" the model's behavior globally.
#                  Leave blank for no system prompt, or enter your own.
#     Example:     OllamaChat.SystemPrompt = "Always answer as if you are a WoW quest giver."
#     Default:     (empty)
OllamaChat.SystemPrompt =

# OllamaChat.Seed
#     Description: Optional. Random seed for deterministic generation. Set to a number for repeatable results, or leave blank for normal random output.
#     Example:     OllamaChat.Seed = 42
#     Default:     (empty)
OllamaChat.Seed =

# OllamaChat.ApiMode
#     Which Ollama-compatible endpoint to call.
#     "generate" -> POST /api/generate (prompt + top-level system) — legacy/default.
#     "chat"     -> POST /api/chat (messages[] array; reply at .message.content).
#     Use "chat" for backends that only apply the model chat template on /api/chat
#     (e.g. Lemonade NPU). When "chat", set OllamaChat.Url to the /api/chat endpoint
#     and supply the persona via OllamaChat.SystemPrompt (no Modelfile on /api/chat).
#     Default: generate
OllamaChat.ApiMode = generate

# OllamaChat.TrimRunaway
#     1 -> cut the reply at the first runaway/stop marker (see RunawayPatterns).
#     Guards against backends that don't always honor stop tokens (NPU runtimes).
#     Default: 1
OllamaChat.TrimRunaway = 1

# OllamaChat.RunawayPatterns
#     "|"-separated literal substrings; the reply is truncated at the earliest match.
#     Use \n for newline. Empty -> no trimming.
#     NOTE: a pattern cannot itself contain the "|" delimiter, so chat-template tokens
#     like <|eot_id|> / <|im_end|> are NOT listed here — put those in OllamaChat.Stop.
#     Default below covers fake chat turns and wiki/edit artifacts.
OllamaChat.RunawayPatterns = \n\nUser:|\n\nAssistant:|\n\nHuman:|\nNote:|\nEdited|\n[[|Wikipedia

# OllamaChat.PromptSalt
#     1 -> append a unique per-request tag to the system prompt so the deterministic
#          Lemonade NPU yields varied replies for same-context bots. 0 = byte-for-byte legacy.
#     The tag is never spoken (validated leak-free); excluded from sentiment classification.
#     Default: 1
OllamaChat.PromptSalt = 1

# OllamaChat.MaxConcurrentQueries
#     Description: The maximum number of concurrent API queries allowed. Use 0 for no limit.
#     Default:     0
OllamaChat.MaxConcurrentQueries = 0
#
#    OllamaChat.MaxQueueDepth
#        Description: Max bot-chat requests waiting behind the in-flight one before new ones are dropped (bot stays silent).
#                     0 = unbounded queue (legacy behavior).
#        Default:     0
OllamaChat.MaxQueueDepth = 0
#
#    OllamaChat.QueueMaxAgeMs
#        Description: Drop a queued chat request once it has waited longer than this (ms) instead of replying late.
#                     0 = no staleness deadline (legacy behavior).
#        Default:     0
OllamaChat.QueueMaxAgeMs = 0
#
# OllamaChat.PrioritizeReplies
#     When 1, player-directed replies (High) preempt queued ambient chatter / sentiment (Normal),
#     and a reply may evict the oldest queued ambient line to claim a slot under MaxQueueDepth.
#     When 0, all traffic shares one FIFO. Only matters once MaxConcurrentQueries/MaxQueueDepth bound the queue.
#     Default: 1
OllamaChat.PrioritizeReplies = 1

# --------------------------------------------
# THINK MODE SUPPORT
# --------------------------------------------

# OllamaChat.ThinkModeEnableForModule
#     Description: Enables Think Mode for supported LLM models. When enabled, the API request will include the "think" flag,
#                  and only the main response will be returned, with all <think> tags and their contents stripped from bot replies.
#                  Make sure you set OllamaChat.NumPredict = 0 (unlimited) when using Think Mode.
#                  Certain models that require Think Mode must have this enabled to function properly.
#     Default:     0 (false)
OllamaChat.ThinkModeEnableForModule = 0

# --------------------------------------------
# GENERAL CHATTER / RESPONSE LOGIC
# --------------------------------------------

# OllamaChat.PlayerReplyChance.Say
#     Description: The percent chance (0-100) that an eligible bot replies to a player in Say/Yell channels.
#     Default:     90
OllamaChat.PlayerReplyChance.Say = 90

# OllamaChat.BotReplyChance.Say
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in Say/Yell channels.
#     Default:     10
OllamaChat.BotReplyChance.Say = 10

# OllamaChat.PlayerReplyChance.Channel
#     Description: The percent chance (0-100) that an eligible bot replies to a player in custom channels (General, Trade, etc.).
#     Default:     60
OllamaChat.PlayerReplyChance.Channel = 60

# OllamaChat.BotReplyChance.Channel
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in custom channels (General, Trade, etc.).
#     Default:     3
OllamaChat.BotReplyChance.Channel = 3

# OllamaChat.PlayerReplyChance.Party
#     Description: The percent chance (0-100) that an eligible bot replies to a player in Party/Raid chat.
#     Default:     90
OllamaChat.PlayerReplyChance.Party = 90

# OllamaChat.BotReplyChance.Party
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in Party/Raid chat.
#     Default:     25
OllamaChat.BotReplyChance.Party = 25

# OllamaChat.PlayerReplyChance.Guild
#     Description: The percent chance (0-100) that an eligible bot replies to a player in Guild/Officer chat.
#     Default:     70
OllamaChat.PlayerReplyChance.Guild = 70

# OllamaChat.BotReplyChance.Guild
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in Guild/Officer chat.
#     Default:     5
OllamaChat.BotReplyChance.Guild = 5

# OllamaChat.EnableWhisperReplies
#     Description: Enable or disable bot responses to whisper messages.
#                  When set to 0 (false), bots will not reply to any whispers.
#                  When set to 1 (true), bots will reply to whispers based on normal reply chances.
#     Default:     0 (false)
OllamaChat.EnableWhisperReplies = 0

# OllamaChat.MaxBotsToPick
#     Description: The maximum number of bots that can be randomly selected to reply when no bot name is explicitly mentioned.
#     Default:     2
OllamaChat.MaxBotsToPick = 2

# OllamaChat.BlacklistCommands
#     Description: A comma-separated list of command prefixes that should be ignored by AI bots.
#                  If a message starts with any of these prefixes, the bot will not respond.
#     Default:     
OllamaChat.BlacklistCommands = autogear,talents,reset botAI,summon,release,revive,leave,attack,follow,flee,stay,runaway,grind,disperse,give leader,spells,cast ,quests,accept,drop,talk,reset,ss ,trainer,rti,rtsc,do ,ll ,e ,ue ,nc ,open,destroy,s ,b ,bank,gb ,u ,co ,ELVUI_VERSIONCHK,Asked,DPSMate_,LibGroupTalents,BLT,oRA3,Skada,HealBot,hbComms,questie,pfQuest,DBMv4-Ver,BWVQ3,add,remove,reset ai,report,state,help,log,stats,tank,offtank,healer,cc ,damage,boost,passive,defensive,aggressive,stay,guard,free,follow,assist,pet,stance,formation,rpg,emote,cheer,applaud,drink,eat,dance,attackers,reset instances,home,zone,who ,pos ,tele,grind,loot,quest,trainer,travel,teleport,homebind,unfollow,invite,uninvite,join,leave,leader,ready,release,save,update,reset talents,gear,trade,mail,ah ,ahscan,ahbid,ahbuy,ahsell,ahcancel,bag,repair,vendor,train,spells,reset spells,learn,unlearn,cast,uncast,use ,move,go ,look,stop,turn,face,wait,party,followleader,stayleader,moveleader,info,distance,debug,reset path,reset state,reset all,reset dungeon,reset raid,zone info,LHC40,RECOUNT,GTFO_v,Altoholic,DS_,DataStore

# OllamaChat.SayDistance
#     Description: The maximum distance (in game units) a bot must be within to reply on a Say message.
#     Default:     30.0
OllamaChat.SayDistance = 30.0

# OllamaChat.YellDistance
#     Description: The maximum distance (in game units) a bot must be within to reply on a Yell message.
#     Default:     100.0
OllamaChat.YellDistance = 100.0

# OllamaChat.DisableForCustomChannels
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in custom channels (General, Trade, LookingForGroup, etc.).
#                  This allows you to reduce spam in public channels while keeping bot interactions in other chat types.
#     Default:     0 (false)
OllamaChat.DisableForCustomChannels = 0

# OllamaChat.DisableForSayYell
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in Say and Yell channels.
#                  Useful if you want bots to be silent in proximity-based chats.
#     Default:     0 (false)
OllamaChat.DisableForSayYell = 0

# OllamaChat.DisableForGuild
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in Guild and Officer channels.
#                  Useful for keeping guild chat focused without bot chatter.
#     Default:     0 (false)
OllamaChat.DisableForGuild = 0

# OllamaChat.DisableForParty
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in Party and Raid channels.
#                  Useful if you want party chat to be bot-free.
#     Default:     0 (false)
OllamaChat.DisableForParty = 0

# --------------------------------------------
# RANDOM CHATTER SYSTEM
# --------------------------------------------

# OllamaChat.EnableRandomChatter
#     Description: Enable or disable random chatter from AI bots when a real player is nearby.
#     Default:     1 (true)
OllamaChat.EnableRandomChatter = 1

# OllamaChat.DisableRepliesInCombat
#     Description: If true, bots will not reply or produce random chatter when in combat.
#     Default:     1
OllamaChat.DisableRepliesInCombat = 1

# OllamaChat.MinRandomInterval
#     Description: The minimum time (in seconds) between random lines from an AI bot.
#     Default:     45
OllamaChat.MinRandomInterval = 45

# OllamaChat.MaxRandomInterval
#     Description: The maximum time (in seconds) between random lines from an AI bot.
#     Default:     180
OllamaChat.MaxRandomInterval = 180

# OllamaChat.RandomChatterRealPlayerDistance
#     Description: The maximum distance (in game units) a real player must be within for random bot chatter to trigger.
#     Default:     200.0
OllamaChat.RandomChatterRealPlayerDistance = 200.0

# OllamaChat.RandomChatterBotCommentChance
#     Description: The percent chance (0-100) that an AI bot will add a comment when random chatter is triggered.
#     Default:     5
OllamaChat.RandomChatterBotCommentChance = 5

# OllamaChat.RandomChatterMaxBotsPerPlayer
#     Description: The maximum number of AI bots that can trigger per random chatter update when a real player is nearby.
#                  This limits how many bots can respond at once to avoid spam.
#                   Each bot can only process once per tick, no duplicates if multiple real players are close.
#     Default:     2
OllamaChat.RandomChatterMaxBotsPerPlayer = 2

# OllamaChat.RandomChatterPromptTemplate
#   Description: The template string for random bot chatter prompts.
#   Placeholders (named): {bot_name} {bot_level} {bot_class} {bot_race} {bot_gender} {bot_role} {bot_faction} {bot_area} {bot_zone} {bot_map} {bot_personality} {bot_personality_name} {environment_info}
#   Note: {bot_personality_name} contains the name/key of the personality (e.g., "grumpy", "helpful"), while {bot_personality} contains the full personality description text.
OllamaChat.RandomChatterPromptTemplate = "You are {bot_name}, a {bot_race} {bot_class} of the {bot_faction}, standing in {bot_area} of {bot_zone}. Personality: {bot_personality_name}: {bot_personality}. {environment_info} Speak aloud in under 15 words about your immediate surroundings — what is here in {bot_area}, what you see, who passes, the work or trouble of this very place. Do not raise the wider war, the Scourge, or the Lich King unless you stand at a front where that fight is being waged."

# OllamaChat.RandomChatterPromptVariations
#   Description: Pipe-separated (|) list of additional prompt instructions that will be randomly selected and appended to the RandomChatterPromptTemplate.
#                This adds variety to bot responses by changing the angle or focus of their random chatter.
#                One variation is randomly chosen each time a bot generates random chatter.
#                Leave empty to disable variations and use only the base template.
#   Example:     "Talk about the weather or environment.|Comment on your current task or goal.|Make an observation about nearby creatures or players."
#   Default:     (see below for Wrath-era appropriate variations)
OllamaChat.RandomChatterPromptVariations = "Mutter about the weather right here.|Comment on the nearest building, road, or landmark.|Wonder aloud about the price of bread, ale, or something local.|Curse a local pest, beast, or bit of bad weather.|Speak of a recent encounter on the road into this place.|Note a smell, sound, or sight close at hand.|Comment on the tavern, inn, or quartermaster of this town.|Recall a rumor heard recently in this region.|Pray briefly to the Light, the ancestors, Elune, or the Earth Mother.|Speak of an old wound that still aches.|Mention a kinsman or comrade you parted from nearby.|Voice unease about a stranger passing close by.|Comment on the wildlife or terrain in plain sight.|Wonder aloud about news from a neighbouring town.|Mention hunger, thirst, sore feet, or a long road still ahead.|Speak of a trader or vendor's craft you noticed today.|Note what you carry, or what you mean to buy or sell here.|Speak of a small task you mean to do before nightfall.|Voice longing for somewhere quieter, or louder, than this.|Mention the road you walked to get here."

# OllamaChat.RandomChatterQuestionVariations
#   Description: Pipe-separated (|) list of prompt instructions telling the LLM to generate questions that will stimulate OTHER bots or players to respond.
#                When a bot uses one of these variations, the LLM will generate a question based on the prompt instruction.
#                These questions are meant to encourage other bots (via BotReplyChance) and real players to engage in conversation.
#                When a bot generates random chatter, it will randomly choose between making a statement (RandomChatterPromptVariations)
#                or asking a question (RandomChatterQuestionVariations).
#                Leave empty to disable question variations and only use statement variations.
#   Example:     "Ask about dungeon preferences.|Ask if anyone wants to PvP.|Ask about raid progression."
#   Default:     (see below for engaging Wrath-era question prompts designed to stimulate bot-to-bot and player-to-bot conversations)
OllamaChat.RandomChatterQuestionVariations = "Ask if the road nearby is safe to travel.|Ask what the local inn or tavern is like.|Ask after a kinsman or companion in this region.|Ask for word from a neighbouring town.|Ask what beast or bandit has been troubling this area.|Ask about the local quartermaster, smith, or innkeeper.|Ask if anyone here knows a good place to rest.|Ask if the herd, harvest, or hunt is going well in these parts.|Ask if a stranger passing by seems friend or foe.|Ask about a recent rumour in this town.|Ask after a missing companion last seen close to here.|Ask if anyone needs an extra blade on the road.|Ask what brings the stranger to these lands.|Ask about strange lights or sounds in the night.|Ask whether the locals deal fairly with outsiders.|Ask whether the local elder, chief, or magistrate has spoken lately.|Ask where the nearest healer or priest can be found.|Ask whether work or coin can be found nearby.|Ask after the weather to come.|Ask what is brewing in the kettle at the nearest inn."

# --------------------------------------------
# EVENT CHATTER SYSTEM
# --------------------------------------------

# OllamaChat.EnableEventChatter
#     Description: Enables or disables the event-based chatter system (e.g. player deaths, entering zones).
#                  When enabled (1), bots will respond to predefined game events.
#     Default:     1 (true)
OllamaChat.EnableEventChatter = 1

# OllamaChat.EventChatterRealPlayerDistance
#     Description: The maximum distance (in game units) a real player must be within to trigger event-based bot chatter.
#     Default:     40.0
OllamaChat.EventChatterRealPlayerDistance = 40.0

# OllamaChat.EventChatterBotCommentChance
#     Description: The percent chance (0–100) that an AI bot will respond to a game event another player generates.
#     Default:     25
OllamaChat.EventChatterBotCommentChance = 25

# OllamaChat.EventChatterBotSelfCommentChance
#     Description: The percent chance (0–100) that an AI bot will respond to a game event it generates itself.
#     Default:     5
OllamaChat.EventChatterBotSelfCommentChance = 5

# OllamaChat.EventChatterMaxBotsPerPlayer
#     Description: The maximum number of bots allowed to respond to a single player's event.
#     Default:     2
OllamaChat.EventChatterMaxBotsPerPlayer = 2

# OllamaChat.EventChatterPromptTemplate
#     Description: The template used to generate bot prompts when reacting to world events.

#     Placeholders (named): {bot_name} {bot_level} {bot_class} {bot_race} {bot_gender} {bot_role} {bot_faction} {bot_area} {bot_zone} {bot_map} {bot_personality} {bot_personality_name} {event_type} {event_detail} {actor_name} {actor_descriptor} {sentiment_info}
#     Note: {bot_personality_name} contains the name/key of the personality (e.g., "grumpy", "helpful"), while {bot_personality} contains the full personality description text.
#     Note: {actor_descriptor} expands to a gender-bearing description for player/bot actors (e.g. "Thrall, a male Orc Warrior") and falls back to {actor_name} for creatures.
OllamaChat.EventChatterPromptTemplate = "You are {bot_name}, a {bot_race} {bot_class} of the {bot_faction}, standing in {bot_area} of {bot_zone}. Personality: {bot_personality_name}: {bot_personality}. {sentiment_info} You have just witnessed: {actor_descriptor} {event_type} {event_detail}. React in under 15 words, grounded in what just happened here in {bot_area} — not in the wider war."

#
#    OllamaChat.ActivityEvents.Enable
#        Master switch for chat lines fired by bot activity lifecycle events
#        (start/finish). Default: 0
#
OllamaChat.ActivityEvents.Enable = 0

#
#    OllamaChat.ActivityEvents.Chance
#        Percent chance (0-100) a bot speaks on a given activity start/finish.
#        Default: 20
#
OllamaChat.ActivityEvents.Chance = 20

#
#    OllamaChat.ActivityChatterPromptTemplate
#        First-person scaffold for activity lines. {activity_instruction} is filled
#        from the mod_ollama_chat_activity_prompts table per (activity,lifecycle).
#
OllamaChat.ActivityChatterPromptTemplate = "You are {bot_name}, a {bot_race} {bot_class} of the {bot_faction}, in {bot_area} of {bot_zone}. Personality: {bot_personality_name}: {bot_personality}. {activity_instruction}"

# --------------------------------------------
# TYPING SIMULATION
# --------------------------------------------

# OllamaChat.EnableTypingSimulation
#     Description: When enabled (1), bots will delay their responses proportionally to the message length
#                  to simulate realistic typing behavior. The delay is calculated as:
#                  BaseDelay + (MessageLength * DelayPerChar) milliseconds
#                  Example: 100 character message with defaults = 1000ms + (100 * 250ms) = 26 seconds
#     Default:     0 (false)
OllamaChat.EnableTypingSimulation = 0

# OllamaChat.TypingSimulationBaseDelay
#     Description: Base delay in milliseconds before a bot starts "typing" a response.
#                  This simulates the time it takes to read the message and start typing.
#     Default:     1000
OllamaChat.TypingSimulationBaseDelay = 1000

# OllamaChat.TypingSimulationDelayPerChar
#     Description: Additional delay in milliseconds per character in the bot's response.
#                  Realistic typing speeds:
#                  - 400ms per char = 2.5 chars/sec (slow/casual)
#                  - 250ms per char = 4 chars/sec (average human)
#                  - 150ms per char = 6.7 chars/sec (proficient)
#                  - 100ms per char = 10 chars/sec (professional)
#     Default:     250
OllamaChat.TypingSimulationDelayPerChar = 250

# OllamaChat.SpeechSplitEnable
#     When enabled (1), a bot reply is delivered as one-or-more chat lines: newlines split
#     into separate /say lines and over-long lines split at sentence boundaries. 0 = legacy single message.
#     Default: 1
OllamaChat.SpeechSplitEnable = 1

# OllamaChat.SpeechSplitMaxLineLength
#     Byte length above which a single line is further split at the last sentence terminator (or space)
#     before the limit. 0 disables length splitting.
#     Default: 230
OllamaChat.SpeechSplitMaxLineLength = 230

# OllamaChat.SpeechSplitDropTrailingFragment
#     When 1, if a multi-line reply ends with a cut-off prose fragment (no terminal punctuation, not a
#     bracketed action), that last fragment is dropped. Never empties a reply.
#     Default: 1
OllamaChat.SpeechSplitDropTrailingFragment = 1

# OllamaChat.SpeechSplitLineDelayMs
#     Delay in ms between consecutive lines of one bot utterance.
#     Default: 700
OllamaChat.SpeechSplitLineDelayMs = 700

# --------------------------------------------
# RP PERSONALITIES SYSTEM
# --------------------------------------------

# OllamaChat.EnableRPPersonalities
#     Description: Enables or disables the use of defined roleplay personalities for AI bots.
#                  When enabled (1), bots will respond with distinct personalities based on their assigned type.
#                  When disabled (0), bots will use a neutral/default response style.
#     Default:     0 (false)
OllamaChat.EnableRPPersonalities = 1

# OllamaChat.DefaultPersonalityPrompt
#     Description: The fallback personality description used when a bot has no specific roleplay type assigned.
#     Default:     Talk like a standard WoW player.
OllamaChat.DefaultPersonalityPrompt = "A weathered, plain-spoken traveler — guarded with strangers, loyal to your kin."

# --------------------------------------------
# CONVERSATION HISTORY AND SNAPSHOT SYSTEM
# --------------------------------------------

# OllamaChat.EnableChatHistory
#     Description: Enables or disables the use of Chat History.
#     Default:     1 (true)
OllamaChat.EnableChatHistory = 1

# OllamaChat.MaxConversationHistory
#     Description: The maximum number of recent message pairs (player + bot reply) to track per bot/player combination.
#                  This history is stored in memory and included in the LLM prompt when the same player talks to the bot again.
#     Default:     5
OllamaChat.MaxConversationHistory = 5

# OllamaChat.ConversationHistorySaveInterval
#     Description: The interval (in minutes) between periodic saves of conversation history from memory to the database.
#                  Set to 0 to disable auto-saving.
#     Default:     10
OllamaChat.ConversationHistorySaveInterval = 10

# OllamaChat.EnableChatBotSnapshotTemplate
#     Description: Enable or disable additional awareness context for each bot.
#                  When enabled (1), the bot will include a snapshot of its current status and surroundings in the chat prompt.
#                  This includes combat status, group info, known spells, active quests, line of sight objects, and nearby players.
#                  When disabled (0), this context is not included in the chat prompt.
#                  This is useful for bots that need to be aware of their environment and current status.
#                  Enabling this may increase the response time and token usage of the API calls.
#     Default:     0 (false)
OllamaChat.EnableChatBotSnapshotTemplate = 1

# OllamaChat.ChatHistoryHeaderTemplate
#   Description: Format for header in conversation history context.
#   Placeholders (named): {player_name}
OllamaChat.ChatHistoryHeaderTemplate = "Recent chats with {player_name}. Use only for context. Reply to the new message."

# OllamaChat.ChatHistoryLineTemplate
#   Description: Format for each line in conversation history context.
#   Placeholders (named): {player_name} {player_message} {bot_reply}
OllamaChat.ChatHistoryLineTemplate = "{player_name} said: {player_message}\nYou said: {bot_reply}\n"

# OllamaChat.ChatHistoryFooterTemplate
#   Description: Format for footer in conversation history context.
#   Placeholders (named): {player_name} {player_message}
OllamaChat.ChatHistoryFooterTemplate = "NEW MESSAGE from {player_name}: {player_message}"

# OllamaChat.ChatBotSnapshotTemplate
#   Description: The template string for the context snapshot of the bot's surroundings and status.
#   Placeholders (named): {combat} {group} {spells} {quests} {los} {players}
OllamaChat.ChatBotSnapshotTemplate = " [Your present circumstance (true things): weave any that fit naturally and briefly into your reply as a person would, never as a list, never quoting numbers, levels, ranks, or game terms.] {combat} {quests} {group} {los} {players} {spells}"
OllamaChat.SnapshotMaxQuests    = 3
OllamaChat.SnapshotMaxGroup     = 4
OllamaChat.SnapshotMaxCreatures = 2
OllamaChat.SnapshotMaxPlayers   = 2
OllamaChat.SnapshotMaxSpells    = 2
OllamaChat.AntiRepetition.Enable = 1
OllamaChat.AntiRepetition.Window = 6
OllamaChat.AntiRepetitionTemplate = " [You recently said these - do not repeat them; say something clearly different and fresh: {recent_replies}]"
OllamaChat.ConversationThreading.Enable = 1
OllamaChat.ConversationThreadWindow = 8
OllamaChat.ConversationThreadTTLMinutes = 30
OllamaChat.ConversationThreadMaxChannels = 64
OllamaChat.ConversationThreadTemplate = " [Recent talk in this channel - join in, reply to the latest naturally, do not just repeat others: {thread}]"
OllamaChat.ChannelFrames.Enable = 1
OllamaChat.ChannelTopics.Enable = 1

OllamaChat.ChannelFrame.Guild   = "You're chatting in your guild channel, among guildmates who know you well - guild life, shared plans, camaraderie."
OllamaChat.ChannelFrame.Party   = "You're speaking to your adventuring group - the task at hand, your companions, what's right in front of you."
OllamaChat.ChannelFrame.Raid    = "You're addressing the whole raid - the fight ahead, coordination, the stakes of a big undertaking."
OllamaChat.ChannelFrame.Say     = "You speak aloud to whoever stands nearby - remark on your surroundings, passers-by, the moment."
OllamaChat.ChannelFrame.Yell    = "You raise your voice for all nearby to hear - a call, a warning, an announcement."
OllamaChat.ChannelFrame.General = "You're posting in the regional General channel - anyone in the area might read it - idle musings, questions, regional happenings."
OllamaChat.ChannelFrame.Trade   = "You're posting in the Trade channel - goods, services, deals, and the usual rabble of a marketplace."
OllamaChat.ChannelFrame.Others  = "You're speaking in a public channel to a broad audience."

OllamaChat.ChannelTopics.Guild   = a guild raid being planned|a guildmate's recent deed|recruiting new blood|the state of the guild bank|an upcoming gathering|an old shared story
OllamaChat.ChannelTopics.Party   = the next pull ahead|loot that just dropped|a narrow escape|where to head next|a companion's gear or skill
OllamaChat.ChannelTopics.Raid    = the great foe ahead|holding the line together|who stands where|the spoils of victory|steeling nerves before the fight
OllamaChat.ChannelTopics.Say     = the scenery or weather|a passing stranger|a beast prowling nearby|news of this town|a rumor lately overheard
OllamaChat.ChannelTopics.Yell    = a call for aid|warning of danger near|seeking companions for a venture|a triumphant boast
OllamaChat.ChannelTopics.General = idle musings|a question for the region|something seen on the road|local happenings|seeking advice

OllamaChat.ChannelWeight.Say     = 30
OllamaChat.ChannelWeight.Yell    = 5
OllamaChat.ChannelWeight.Party   = 20
OllamaChat.ChannelWeight.Raid    = 15
OllamaChat.ChannelWeight.Guild   = 25
OllamaChat.ChannelWeight.General = 15

OllamaChat.ChannelTopics.Trade   =
OllamaChat.ChannelTopics.Others  =
OllamaChat.ChannelWeight.Trade   = 0
OllamaChat.ChannelWeight.Others  = 0
#
#    OllamaChat.OccupationChatter.Enable
#        While a bot is engaged in a NewRpg occupation (any of the 16 behaviors below)
#        occasionally inject an occupation-themed topic into its initiated chatter and
#        force it to a local Say line.
#        Default: 1 (enabled)
#
OllamaChat.OccupationChatter.Enable = 1
#
#    OllamaChat.OccupationChatter.Chance
#        Percent chance (0-100), per eligible initiated message while engaged in an
#        occupation, to inject the occupation topic. Default: 40
#
OllamaChat.OccupationChatter.Chance = 40
#
#    OllamaChat.OccupationTopics.<behavior>
#        Pipe-delimited ( | ) list of topics the bot may bring up for each behavior,
#        rewritten in its own personality voice by the LLM. One list per behavior.
#        An empty list means that behavior contributes no themed topic (graceful skip).
#        Behavior keys (the 16 rationalized behaviors):
#          go_grind, wander_random, do_quest, gathering_circuit, rest, wander_npc,
#          travel_flight, travel_mount, outdoor_pvp, social, loiter, fish, craft,
#          duel, repair_sell, dummy
#        Most ship empty by default; the 5 below carry the migrated legacy pools.
#
OllamaChat.OccupationTopics.social = "the good company at this gathering|how pleasant it is to relax with others for a while|an old friend you ran into here"
OllamaChat.OccupationTopics.fish = "the fish finally biting|the big catch you are hoping to land|how peaceful it is to fish by the water|the one that got away"
OllamaChat.OccupationTopics.gathering_circuit = "a rich vein or herb you just spotted|the materials you have been collecting|how the day's gathering is going"
OllamaChat.OccupationTopics.craft = "the piece you are working on|honing your trade skill|a recipe you have been wanting to try|the quality of your latest work"
OllamaChat.OccupationTopics.duel = "a friendly duel to test your skills|how the sparring is going|a worthy opponent you just faced"
#
#    OllamaChat.OccupationTopics.loiter.<poi>
#        The loiter behavior resolves its topic by the city point-of-interest the bot
#        dwells at. POI keys: auctioneer, banker, innkeeper, trainer, mailbox, forge.
#        (forge has no legacy pool; it defaults to empty.) Falls back to the plain
#        OllamaChat.OccupationTopics.loiter list when a POI list is empty.
#
OllamaChat.OccupationTopics.loiter.auctioneer = "the outrageous auction prices|a bargain you just spotted at the auction house|something you are hoping to sell"
OllamaChat.OccupationTopics.loiter.banker = "needing to clear out your overstuffed bank|your dwindling gold|the valuables you keep stored away"
OllamaChat.OccupationTopics.loiter.innkeeper = "the comforts of the inn|the food and drink served here|setting your hearthstone"
OllamaChat.OccupationTopics.loiter.trainer = "a new skill you wish to learn|the steep cost of training|mastering your craft"
OllamaChat.OccupationTopics.loiter.mailbox = "a letter you have been waiting for|mail from an old friend|a package that still has not arrived"
OllamaChat.OccupationTopics.loiter.forge =

# ----------------------------------------------
# CROSS-BOT ANTI-REPETITION (Say-range awareness)
# ----------------------------------------------
# Optionally lets a bot see the recent lines spoken by OTHER bots within Say range and be told
# not to echo them, so co-located bots diversify. Additive to the per-bot guard above; reuses the
# same recent-reply buffer (no new recording). Ships DISABLED: run a measurement pass first with
# OllamaChat.DebugEnabled = 1 and grep the log for "CROSSREP hit" to see if echoing actually
# happens on your server before enabling.
# Default: 0 (disabled)
OllamaChat.CrossBotAntiRepetition.Enable = 0

# Recent lines pulled from EACH nearby bot.
# Default: 2
OllamaChat.CrossBotAntiRepetition.Window = 2

# Hard cap on the total number of nearby lines injected into one prompt (bounds prompt growth).
# Default: 6
OllamaChat.CrossBotAntiRepetition.MaxLines = 6

# Instruction wrapper. Use {nearby_replies} for the (quoted, " | "-joined) nearby lines.
# Default: " [Others near you recently said these - say something different, do not echo them: {nearby_replies}]"
OllamaChat.CrossBotAntiRepetitionTemplate = " [Others near you recently said these - say something different, do not echo them: {nearby_replies}]"

# ----------------------------------------------
# SENTIMENT TRACKING SYSTEM
# ----------------------------------------------

# Enable or disable sentiment tracking between bots and players
# Disabled by default due to needing an extra LLM call.
# Default: 0 (disabled)
OllamaChat.EnableSentimentTracking = 0

# Default sentiment value for new bot-player relationships
# Range: 0.0 (hostile) to 1.0 (friendly), 0.5 = neutral
# Default: 0.5
OllamaChat.SentimentDefaultValue = 0.5

# How much to adjust sentiment per positive/negative message
# Range: 0.01 to 0.5 (smaller = more gradual changes)
# Default: 0.05
OllamaChat.SentimentAdjustmentStrength = 0.05

# How often to save sentiment data to database (in minutes)
# Set to 0 to disable periodic saving
# Default: 10
OllamaChat.SentimentSaveInterval = 10

# Prompt template for sentiment analysis
# Use {message} placeholder for the message to analyze
# Default: "Analyze the sentiment of this message: \"{message}\". Respond only with: POSITIVE, NEGATIVE, or NEUTRAL."
OllamaChat.SentimentAnalysisPrompt = "Analyze the sentiment of this message: \"{message}\". Respond only with: POSITIVE, NEGATIVE, or NEUTRAL."

# Template for including sentiment information in bot prompts
# Use {player_name} and {sentiment_value} placeholders
# Default: "Your relationship sentiment with {player_name} is {sentiment_value} (0.0=hostile, 0.5=neutral, 1.0=friendly). Use this to guide your tone and response."
OllamaChat.SentimentPromptTemplate = "Your relationship sentiment with {player_name} is {sentiment_value} (0.0=hostile, 0.5=neutral, 1.0=friendly). Use this to guide your tone and response."

# --------------------------------------------
# CHAT/PROMPT TEMPLATES
# --------------------------------------------

# OllamaChat.ChatPromptTemplate
#   Description: The main template for bot chat prompts sent to the LLM.
#   Placeholders (named): {bot_name} {bot_level} {bot_class} {bot_personality} {bot_personality_name} {player_level} {player_class} {player_name} {player_descriptor} {bot_descriptor} {player_message} {extra_info} {sentiment_info}
#   Note: {bot_personality_name} contains the name/key of the personality (e.g., "grumpy", "helpful"), while {bot_personality} contains the full personality description text.
OllamaChat.ChatPromptTemplate = "You are {bot_name}, a {bot_class}. Personality: {bot_personality_name}: {bot_personality}. {sentiment_info} {chat_history} {player_descriptor} says to you: '{player_message}'. {extra_info} Reply in under 20 words. Answer what they actually asked — speak of your surroundings, the local lands, your craft, or your kin. Raise the wider war, the Scourge, or the Lich King only if they bring them up or you stand at a war front. No prefix."

# OllamaChat.ChatExtraInfoTemplate
#   Description: The context/details string about the bot and player, injected into the chat prompt as the last parameter.
#   Placeholders (named): {bot_race} {bot_gender} {bot_role} {bot_faction} {bot_guild} {bot_group_status} {bot_gold} {player_race} {player_gender} {player_role} {player_faction} {player_guild} {player_group_status} {player_gold} {player_distance} {bot_area} {bot_zone} {bot_map}
OllamaChat.ChatExtraInfoTemplate = "Your Info: {bot_race} {bot_gender}, Spec: {bot_role}, Faction: {bot_faction}, Guild: {bot_guild}, Group: {bot_group_status}, Gold: {bot_gold}. Player Info: {player_race} {player_gender}, Spec: {player_role}, Faction: {player_faction}, Guild: {player_guild}, Group: {player_group_status}, Gold: {player_gold}, Distance: {player_distance} yards. You stand in {bot_area}, in the wider land of {bot_zone}. Only respond to the new message. No commentary, no meta-talk, no prefix—just the reply."

# --------------------------------------------
# ENVIRONMENTAL/CONTEXTUAL TEMPLATES
# --------------------------------------------

# OllamaChat.EnvCommentCreature
#   Description: A pipe-separated (|) list of template messages for when any creature is spotted nearby.
#   Placeholders (named): {creature_name}
OllamaChat.EnvCommentCreature = You spot a creature named '{creature_name}' and react cautiously.|You spot a creature named '{creature_name}' and assess its threat.|You spot a creature named '{creature_name}' and comment on its behavior.|You spot a creature named '{creature_name}' and consider whether to engage.|You spot a creature named '{creature_name}' and recall what you know about it.|You spot a creature named '{creature_name}' and comment on its appearance.|You spot a creature named '{creature_name}' and decide if it should be avoided.|You spot a creature named '{creature_name}' and speculate on its intentions.

# OllamaChat.EnvCommentGameObject
#   Description: A pipe-separated (|) list of template messages for when a game object is nearby.
#   Placeholders (named): {object_name}
OllamaChat.EnvCommentGameObject = You see {object_name} nearby and comment on its purpose.|You see {object_name} nearby and decide whether to interact.|You see {object_name} nearby and recall why it is useful.|You see {object_name} nearby and judge its condition.|You see {object_name} nearby and consider if it is valuable.|You see {object_name} nearby and explain what it might be used for.|You see {object_name} nearby and react with curiosity.|You see {object_name} nearby and decide whether to investigate.

# OllamaChat.EnvCommentEquippedItem
#   Description: A pipe-separated (|) list of template messages referencing a random equipped item.
#   Placeholders (named): {item_name}
OllamaChat.EnvCommentEquippedItem = Talk about your equipped item {item_name} and why you chose it.|Talk about your equipped item {item_name} and how it helps you.|Talk about your equipped item {item_name} and its strengths.|Talk about your equipped item {item_name} and any weaknesses.|Talk about your equipped item {item_name} and how it feels to use.|Talk about your equipped item {item_name} and when it is most effective.|Talk about your equipped item {item_name} and compare it to alternatives.|Talk about your equipped item {item_name} and your confidence in it.

# OllamaChat.EnvCommentBagItem
#   Description: A pipe-separated (|) list of template messages for an item in the bot's bag.
#   Placeholders (named): {item_name}
OllamaChat.EnvCommentBagItem = You notice a {item_name} in your bag and consider using it.|You notice a {item_name} in your bag and explain why you keep it.|You notice a {item_name} in your bag and decide if it is still useful.|You notice a {item_name} in your bag and recall where you got it.|You notice a {item_name} in your bag and judge its value.|You notice a {item_name} in your bag and think about trading it.|You notice a {item_name} in your bag and plan when to use it.|You notice a {item_name} in your bag and comment on its condition.

# OllamaChat.EnvCommentBagItemSell
#   Description: A pipe-separated (|) list of template messages for an item the bot might try to sell.
#   Placeholders (named): {item_count} {item_name}
OllamaChat.EnvCommentBagItemSell = You are trying persuasively to sell {item_count} of this item {item_name} by highlighting its benefits.|You are trying persuasively to sell {item_count} of this item {item_name} by stressing its rarity.|You are trying persuasively to sell {item_count} of this item {item_name} by appealing to need.|You are trying persuasively to sell {item_count} of this item {item_name} by offering a deal.|You are trying persuasively to sell {item_count} of this item {item_name} by explaining its uses.|You are trying persuasively to sell {item_count} of this item {item_name} by comparing it to others.|You are trying persuasively to sell {item_count} of this item {item_name} by creating urgency.|You are trying persuasively to sell {item_count} of this item {item_name} by praising its quality.

# OllamaChat.EnvCommentSpell
#   Description: A pipe-separated (|) list of template messages about a random known spell.
#   Placeholders (named): {spell_name} {spell_effect} {spell_cost}
OllamaChat.EnvCommentSpell = Discuss possible uses or strategies for '{spell_name}' in the current situation.|Discuss possible uses or strategies for '{spell_name}' against different enemies.|Discuss possible uses or strategies for '{spell_name}' when resources are low.|Discuss possible uses or strategies for '{spell_name}' and its risks.|Discuss possible uses or strategies for '{spell_name}' compared to other spells.|Discuss possible uses or strategies for '{spell_name}' in group combat.|Discuss possible uses or strategies for '{spell_name}' outside of combat.|Discuss possible uses or strategies for '{spell_name}' given its cost of {spell_cost}.

# OllamaChat.EnvCommentQuestArea
#   Description: A pipe-separated (|) list of template messages to suggest an area to quest in.
#   Placeholders (named): {quest_area}
OllamaChat.EnvCommentQuestArea = Suggest you could go questing around {quest_area} and explain why.|Suggest you could go questing around {quest_area} based on your level.|Suggest you could go questing around {quest_area} for rewards.|Suggest you could go questing around {quest_area} due to recent rumors.|Suggest you could go questing around {quest_area} to gain experience.|Suggest you could go questing around {quest_area} and note the dangers.|Suggest you could go questing around {quest_area} if prepared.|Suggest you could go questing around {quest_area} and set a goal.

# OllamaChat.EnvCommentVendor
#   Description: A pipe-separated (|) list of template messages when a vendor NPC is nearby.
#   Placeholders (named): {vendor_name}
OllamaChat.EnvCommentVendor = You spot {vendor_name} selling wares nearby and consider browsing.|You spot {vendor_name} selling wares nearby and recall past deals.|You spot {vendor_name} selling wares nearby and check your coin.|You spot {vendor_name} selling wares nearby and judge their stock.|You spot {vendor_name} selling wares nearby and decide whether to trade.|You spot {vendor_name} selling wares nearby and comment on their reputation.|You spot {vendor_name} selling wares nearby and look for upgrades.|You spot {vendor_name} selling wares nearby and compare prices.

# OllamaChat.EnvCommentQuestgiver
#   Description: A pipe-separated (|) list of template messages when a questgiver NPC is nearby.
#   Placeholders (named): {questgiver_name} {quest_count}
OllamaChat.EnvCommentQuestgiver = {questgiver_name} looks like they have {quest_count} quests and you evaluate which to take.|{questgiver_name} looks like they have {quest_count} quests and you judge the risk.|{questgiver_name} looks like they have {quest_count} quests and you consider rewards.|{questgiver_name} looks like they have {quest_count} quests and you recall past work.|{questgiver_name} looks like they have {quest_count} quests and you assess urgency.|{questgiver_name} looks like they have {quest_count} quests and you choose carefully.|{questgiver_name} looks like they have {quest_count} quests and you plan next steps.|{questgiver_name} looks like they have {quest_count} quests and you comment on their tone.

# OllamaChat.EnvCommentBagSlots
#   Description: A pipe-separated (|) list of template messages about available bag slots.
#   Placeholders (named): {bag_slots}
OllamaChat.EnvCommentBagSlots = You have {bag_slots} free bag slots left and decide how cautious to be.|You have {bag_slots} free bag slots left and plan your looting.|You have {bag_slots} free bag slots left and consider selling items.|You have {bag_slots} free bag slots left and comment on inventory pressure.|You have {bag_slots} free bag slots left and adjust priorities.|You have {bag_slots} free bag slots left and plan ahead.|You have {bag_slots} free bag slots left and evaluate risk.|You have {bag_slots} free bag slots left and think about storage.

# OllamaChat.EnvCommentDungeon
#   Description: A pipe-separated (|) list of template messages for when the bot is in a dungeon.
#   Placeholders (named): {dungeon_name}
OllamaChat.EnvCommentDungeon = You're in a Dungeon instance named '{dungeon_name}' and comment on the atmosphere.|You're in a Dungeon instance named '{dungeon_name}' and recall known bosses.|You're in a Dungeon instance named '{dungeon_name}' and plan your approach.|You're in a Dungeon instance named '{dungeon_name}' and assess danger.|You're in a Dungeon instance named '{dungeon_name}' and prepare mentally.|You're in a Dungeon instance named '{dungeon_name}' and comment on layout.|You're in a Dungeon instance named '{dungeon_name}' and recall past runs.|You're in a Dungeon instance named '{dungeon_name}' and set expectations.

# OllamaChat.EnvCommentUnfinishedQuest
#   Description: A pipe-separated (|) list of template messages about a random incomplete quest in the bot's log.
#   Placeholders (named): {quest_name}
OllamaChat.EnvCommentUnfinishedQuest = Say the name of and talk about your un-finished quest '{quest_name}' and what remains.|Say the name of and talk about your un-finished quest '{quest_name}' and its difficulty.|Say the name of and talk about your un-finished quest '{quest_name}' and why it stalled.|Say the name of and talk about your un-finished quest '{quest_name}' and your next step.|Say the name of and talk about your un-finished quest '{quest_name}' and its rewards.|Say the name of and talk about your un-finished quest '{quest_name}' and the risks.|Say the name of and talk about your un-finished quest '{quest_name}' and your motivation.|Say the name of and talk about your un-finished quest '{quest_name}' and its urgency.

# --------------------------------------------
# EVENT TEMPLATES
# --------------------------------------------

# OllamaChat.EventTypeDefeated
#     Description: The event type string for when a player or bot defeats a creature.
#     Used in: Event-based chat prompts. Example: "Kurim defeated Hogger."
#     Default:     defeated
OllamaChat.EventTypeDefeated = defeated
OllamaChat.EventTypeDefeated_Chance = 1

# OllamaChat.EventTypeDefeatedPlayer
#     Description: The event type string for when a player defeats another player (PvP kill).
#     Used in: Event-based chat prompts for PvP kills.
#     Default:     defeated player
OllamaChat.EventTypeDefeatedPlayer = defeated player
OllamaChat.EventTypeDefeatedPlayer_Chance = 10

# OllamaChat.EventTypePetDefeated
#     Description: The event type string for when a player's pet defeats a creature.
#     Used in: Event-based chat prompts.
#     Default:     pet defeated
OllamaChat.EventTypePetDefeated = pet defeated
OllamaChat.EventTypePetDefeated_Chance = 2

# OllamaChat.EventTypeGotItem
#     Description: The event type string for when a player obtains a rare or higher quality item.
#     Used in: Event-based chat when a player gets a notable item.
#     Default:     got item
OllamaChat.EventTypeGotItem = got item
OllamaChat.EventTypeGotItem_Chance = 65

# OllamaChat.EventTypeDied
#     Description: The event type string for when a player dies.
#     Used in: Event-based chat when a player death occurs.
#     Default:     died
OllamaChat.EventTypeDied = died
OllamaChat.EventTypeDied_Chance = 18

# OllamaChat.EventTypeCompletedQuest
#     Description: The event type string for when a player completes a quest.
#     Used in: Event-based chat when a quest is completed.
#     Default:     completed quest
OllamaChat.EventTypeCompletedQuest = completed quest
OllamaChat.EventTypeCompletedQuest_Chance = 35

# OllamaChat.EventTypeLearnedSpell
#     Description: The event type string for when a player learns a new spell.
#     Used in: Event-based chat for spell learning.
#     Default:     learned spell
OllamaChat.EventTypeLearnedSpell = learned spell
OllamaChat.EventTypeLearnedSpell_Chance = 2

# OllamaChat.EventTypeRequestedDuel
#     Description: The event type string for when a player requests a duel.
#     Used in: Event-based chat on duel request.
#     Default:     requested to duel
OllamaChat.EventTypeRequestedDuel = requested to duel
OllamaChat.EventTypeRequestedDuel_Chance = 28

# OllamaChat.EventTypeStartedDueling
#     Description: The event type string for when a duel starts between players.
#     Used in: Event-based chat when a duel begins.
#     Default:     started dueling
OllamaChat.EventTypeStartedDueling = started dueling
OllamaChat.EventTypeStartedDueling_Chance = 10

# OllamaChat.EventTypeWonDuel
#     Description: The event type string for when a player wins a duel.
#     Used in: Event-based chat for duel win.
#     Default:     won duel against
OllamaChat.EventTypeWonDuel = won duel against
OllamaChat.EventTypeWonDuel_Chance = 85

# OllamaChat.EventTypeLeveledUp
#     Description: The event type string for when a player levels up.
#     Used in: Event-based chat on level up.
#     Default:     leveled up
OllamaChat.EventTypeLeveledUp = leveled up
OllamaChat.EventTypeLeveledUp_Chance = 75

# OllamaChat.EventTypeAchievement
#     Description: The event type string for when a player earns an achievement.
#     Used in: Event-based chat for achievements.
#     Default:     earned achievement
OllamaChat.EventTypeAchievement = earned achievement
OllamaChat.EventTypeAchievement_Chance = 75

# OllamaChat.EventTypeUsedObject
#     Description: The event type string for when a player uses a game object.
#     Used in: Event-based chat when using objects in the world.
#     Default:     used object
OllamaChat.EventTypeUsedObject = used object
OllamaChat.EventTypeUsedObject_Chance = 10

# --------------------------------------------
# ADDITIONAL EVENT HOOKS — all default 0 (off / opt-in)
# Each event has a type string (the prompt label) and split chances:
#   PlayerEventChance.<Event> = chance (0-100) when the actor is a real player
#   BotEventChance.<Event>    = chance (0-100) when the actor is a bot
# --------------------------------------------

OllamaChat.EventTypeEnteredZone      = entered zone
OllamaChat.PlayerEventChance.EnteredZone = 0
OllamaChat.BotEventChance.EnteredZone    = 0

OllamaChat.EventTypeKilledByCreature = killed by creature
OllamaChat.PlayerEventChance.KilledByCreature = 0
OllamaChat.BotEventChance.KilledByCreature    = 0

OllamaChat.EventTypeReputationRank   = reputation rank
OllamaChat.PlayerEventChance.ReputationRank = 0
OllamaChat.BotEventChance.ReputationRank    = 0

OllamaChat.EventTypeResurrected      = resurrected
OllamaChat.PlayerEventChance.Resurrected = 0
OllamaChat.BotEventChance.Resurrected    = 0

OllamaChat.EventTypeEnteredCombat    = entered combat
OllamaChat.PlayerEventChance.EnteredCombat = 0
OllamaChat.BotEventChance.EnteredCombat    = 0

OllamaChat.EventTypeLeftCombat       = left combat
OllamaChat.PlayerEventChance.LeftCombat = 0
OllamaChat.BotEventChance.LeftCombat    = 0

# OllamaChat.EventCooldownTime
#     Description: The cooldown time (in seconds) for bots to respond to an event.
#     Default:     10
OllamaChat.EventCooldownTime = 10

# --------------------------------------------
# GUILD-SPECIFIC RANDOM CHATTER
# --------------------------------------------

# OllamaChat.EnableGuildRandomAmbientChatter
#     Description: Enable or disable random ambient guild chatter from bots in guilds with real players online.
#     Default:     1 (true)
OllamaChat.EnableGuildRandomAmbientChatter = 1

# OllamaChat.GuildRandomChatterChance
#     Description: Percent chance (0-100) for a bot to send a random guild chat message when eligible.
#     Default:     10
OllamaChat.GuildRandomChatterChance = 85

# OllamaChat.EnableGuildEventChatter
#     Description: Enable guild-specific random chatter for bots in guilds with real players.
#                  When enabled, bots will make guild-related comments and use guild chat.
#                  Only activates when real players are online in the same guild as the bot.
#     Default: 1 (true)
OllamaChat.EnableGuildEventChatter = 1

# OllamaChat.GuildChatterBotCommentChance
#     Description: Percentage chance (0-100) for guild bots to comment on guild events.
#                  This applies to events like level ups, gear acquisition, dungeon completion.
#                  Lower values = less frequent guild event responses.
#     Default: 65
OllamaChat.GuildChatterBotCommentChance = 65

# OllamaChat.GuildChatterMaxBotsPerEvent
#     Description: Maximum number of guild bots that can respond to a single guild event.
#                  Prevents spam when multiple guild bots want to comment on the same event.
#                  Example: If set to 2, only 2 bots max will respond to a member leveling up.
#     Default: 2
OllamaChat.GuildChatterMaxBotsPerEvent = 2

# --------------------------------------------
# GUILD ENVIRONMENT COMMENT TEMPLATES
# --------------------------------------------

# OllamaChat.GuildEnvCommentGuildMember
#     Description: Templates for commenting on guild members. Pipe-separated (|) list.
#     Placeholders: {member_name}
#     Example: "I wonder what {member_name} is up to today."
#     Default: (empty - no guild member comments)
OllamaChat.GuildEnvCommentGuildMember = I wonder what {member_name} is up to today.|{member_name} is a solid guild member.|Haven't seen {member_name} around much lately.

# OllamaChat.GuildEnvCommentGuildRank
#     Description: Templates for commenting on guild ranks. Pipe-separated (|) list.
#     Placeholders: {guild_rank}
#     Example: "Being a {guild_rank} has its perks."
#     Default: (empty - no guild rank comments)
OllamaChat.GuildEnvCommentGuildRank = Being a {guild_rank} has its perks.|The {guild_rank} rank comes with responsibilities.|I'm proud to be a {guild_rank} in this guild.

# OllamaChat.GuildEnvCommentGuildBank
#     Description: Templates for commenting on guild bank status. Pipe-separated (|) list.
#     Placeholders: {bank_gold}
#     Example: "Guild bank has {bank_gold} gold saved up."
#     Default: (empty - no guild bank comments)
OllamaChat.GuildEnvCommentGuildBank = Guild bank has {bank_gold} gold saved up.|We should check what's in the guild bank.|{bank_gold} gold in the guild bank, not bad.|The guild bank could use some donations.

# OllamaChat.GuildEnvCommentGuildMOTD
#     Description: Templates for commenting on guild message of the day. Pipe-separated (|) list.
#     Placeholders: {guild_motd}
#     Example: "Guild MOTD says: {guild_motd}"
#     Default: (empty - no guild MOTD comments)
OllamaChat.GuildEnvCommentGuildMOTD = Guild MOTD says: {guild_motd}|Did everyone see the guild message? {guild_motd}|The officers updated the MOTD: {guild_motd}

# OllamaChat.GuildEnvCommentGuildInfo
#     Description: Templates for commenting on guild information. Pipe-separated (|) list.
#     Placeholders: {guild_info}
#     Example: "Our guild info reads: {guild_info}"
#     Default: (empty - no guild info comments)
OllamaChat.GuildEnvCommentGuildInfo = Our guild info reads: {guild_info}|Check out the guild info if you haven't: {guild_info}|The guild description says it all: {guild_info}

# OllamaChat.GuildEnvCommentGuildOnlineMembers
#     Description: Templates for commenting on online guild members. Pipe-separated (|) list.
#     Placeholders: {online_count}, {total_count}
#     Example: "We have {online_count} out of {total_count} guild members online."
#     Default: (empty - no online member comments)
OllamaChat.GuildEnvCommentGuildOnlineMembers = We have {online_count} out of {total_count} guild members online.|{online_count} guildies are online right now.|Nice to see {online_count} guild members active today.|Only {online_count} of us online from the guild.

# --------------------------------------------
# GUILD RANDOM CHATTER PROMPTS
# --------------------------------------------

# OllamaChat.GuildEnvCommentGuildRaid
#     Description: Templates for commenting on guild raid activity. Pipe-separated (|) list.
#     Example: "Looking forward to the next guild raid!"
#     Default: (empty - no raid comments)
OllamaChat.GuildEnvCommentGuildRaid = Looking forward to the next guild raid!|Hope we get some good loot in the next raid.|Who's ready for raid night?

# OllamaChat.GuildEnvCommentGuildEndgame
#     Description: Templates for commenting on endgame content. Pipe-separated (|) list.
#     Example: "Endgame content is tough but fun."
#     Default: (empty - no endgame comments)
OllamaChat.GuildEnvCommentGuildEndgame = Endgame content is tough but fun.|We need more people for endgame runs.|Anyone up for some endgame challenges?

# OllamaChat.GuildEnvCommentGuildStrategy
#     Description: Templates for discussing guild strategies. Pipe-separated (|) list.
#     Example: "We should try a new strategy for the next boss."
#     Default: (empty - no strategy comments)
OllamaChat.GuildEnvCommentGuildStrategy = We should try a new strategy for the next boss.|Strategy is key to our success.|Let's discuss tactics for the next fight.

# OllamaChat.GuildEnvCommentGuildGroup
#     Description: Templates for group/quest/grind activity. Pipe-separated (|) list.
#     Example: "Anyone want to group up for quests?"
#     Default: (empty - no group comments)
OllamaChat.GuildEnvCommentGuildGroup = Anyone want to group up for quests?|Grinding with guildies is more fun.|Let's form a group for dailies.

# OllamaChat.GuildEnvCommentGuildPvP
#     Description: Templates for guild PvP activity. Pipe-separated (|) list.
#     Example: "Who's up for some PvP tonight?"
#     Default: (empty - no PvP comments)
OllamaChat.GuildEnvCommentGuildPvP = Who's up for some PvP tonight?|PvP with the guild is always intense.|Let's queue for some battlegrounds together.

# OllamaChat.GuildEnvCommentGuildCommunity
#     Description: Templates for community/social comments. Pipe-separated (|) list.
#     Example: "Guild community is the best part of the game."
#     Default: (empty - no community comments)
OllamaChat.GuildEnvCommentGuildCommunity = Guild community is the best part of the game.|Love hanging out with everyone here.|Our guild socials are always a blast.

# --------------------------------------------
# GUILD EVENT TYPES
# --------------------------------------------

# OllamaChat.GuildEventTypeEpicGear
#     Description: Event type for guild epic gear acquisition announcements.
#                  Creates excitement and congratulations for rare loot.
#     Example:     "Grats on the epic loot!"
#     Default:     guild member got epic gear
OllamaChat.GuildEventTypeEpicGear = guild member got epic gear
OllamaChat.GuildEventTypeEpicGear_Chance = 95

# OllamaChat.GuildEventTypeRareGear
#     Description: Event type for guild rare gear acquisition announcements.
#                  Triggered when a guild member obtains rare (blue) quality weapons or armor.
#                  Only announces equipment, not consumables or trade goods.
#     Example:     "Nice blue gear upgrade!"
#     Default:     guild member got rare gear
OllamaChat.GuildEventTypeRareGear = guild member got rare gear
OllamaChat.GuildEventTypeRareGear_Chance = 65

# OllamaChat.GuildEventTypeGuildJoin
#     Description: Event type for guild member join announcements.
#                  Triggered when a new player joins the guild.
#                  Welcomes new members to the guild community.
#     Example:     "Welcome to the guild!"
#     Default:     member joined guild
OllamaChat.GuildEventTypeGuildJoin = has been sworn into
OllamaChat.GuildEventTypeGuildJoin_Chance = 12

# OllamaChat.GuildEventTypeGuildLogin
#     Description: Event type for guild member login announcements.
#                  Triggered when a non-bot guild member logs in.
#                  Welcomes returning members to the guild.
#     Example:     "{actor_name} has logged in to the guild!"
#     Default:     member logged in
OllamaChat.GuildEventTypeGuildLogin = rejoins the company of
OllamaChat.GuildEventTypeGuildLogin_Chance = 85

# OllamaChat.GuildEventTypeGuildLeave
#     Description: Event type for guild member leave announcements.
#                  Triggered when a player leaves the guild.
#                  Acknowledges departing members.
#     Example:     "Sad to see them go."
#     Default:     member left guild
OllamaChat.GuildEventTypeGuildLeave = has parted ways with
OllamaChat.GuildEventTypeGuildLeave_Chance = 85

# OllamaChat.GuildEventTypeGuildPromotion
#     Description: Event type for guild member promotion announcements.
#                  Triggered when a guild member gets promoted to a higher rank.
#                  Celebrates advancement within the guild hierarchy.
#     Example:     "Congrats on the promotion!"
#     Default:     member got promoted
OllamaChat.GuildEventTypeGuildPromotion = has risen in the ranks of
OllamaChat.GuildEventTypeGuildPromotion_Chance = 25

# OllamaChat.GuildEventTypeGuildDemotion
#     Description: Event type for guild member demotion announcements.
#                  Triggered when a guild member gets demoted to a lower rank.
#                  Handles rank changes sensitively.
#     Example:     "Rank changes happen."
#     Default:     member got demoted
OllamaChat.GuildEventTypeGuildDemotion = has been lowered in rank within
OllamaChat.GuildEventTypeGuildDemotion_Chance = 5

# OllamaChat.GuildEventTypeGuildAchievement
#     Description: Event type for guild member achievement announcements.
#                  Triggered when a real (non-bot) guild member earns an achievement.
#                  Celebrates player accomplishments in the guild.
#     Example:     "{actor_name} just earned an achievement!"
#     Default:     member earned achievement
OllamaChat.GuildEventTypeGuildAchievement = member earned achievement
OllamaChat.GuildEventTypeGuildAchievement_Chance = 85

# OllamaChat.GuildEventTypeLevelUp
#     Description: Event type for guild member level up announcements.
#                  Triggered when a guild member levels up.
#                  Celebrates player progression in the guild.
#     Example:     "Grats on the level up!"
#     Default:     member leveled up
OllamaChat.GuildEventTypeLevelUp = member leveled up
OllamaChat.GuildEventTypeLevelUp_Chance = 95

# OllamaChat.GuildEventTypeDungeonComplete
#     Description: Event type for guild dungeon completion announcements.
#                  Triggered when a guild group completes a dungeon.
#                  Recognizes group achievements in PvE content.
#     Example:     "Dungeon run complete!"
#     Default:     guild group completed a dungeon
OllamaChat.GuildEventTypeDungeonComplete = guild group completed a dungeon
OllamaChat.GuildEventTypeDungeonComplete_Chance = 85

# --------------------------------------------
# RAG (Retrieval-Augmented Generation) SYSTEM
# --------------------------------------------

# OllamaChat.EnableRAG
#     Description: Enable or disable the RAG (Retrieval-Augmented Generation) feature.
#                  When enabled, the bot will analyze player messages and retrieve relevant information
#                  from JSON knowledge base files to provide more accurate and detailed responses.
#     Default:     0 (false)
OllamaChat.EnableRAG = 0



# OllamaChat.RAGDataPath
#     Description: Path to the directory containing RAG JSON data files.
#                  This should be a relative path from the server's working directory.
#                  For AzerothCore installations, this is typically ../../../modules/mod-ollama-chat/data/rag/
#                  The system will load all .json files from this directory.
#     Default:     ../../../modules/mod-ollama-chat/data/rag/
OllamaChat.RAGDataPath = ../../../modules/mod-ollama-chat/data/rag/



# OllamaChat.RAGMaxRetrievedItems
#     Description: Maximum number of relevant information items to retrieve and include in the prompt.
#                  Higher values provide more context but may exceed token limits.
#     Default:     3
OllamaChat.RAGMaxRetrievedItems = 3



# OllamaChat.RAGSimilarityThreshold
#     Description: Minimum similarity score (0.0-1.0) required for information to be considered relevant.
#                  Lower values will include more information but may be less accurate.
#                  Higher values will be more precise but may miss relevant information.
#                  Recommended range: 0.2-0.4 for good balance of relevance and coverage.
#     Default:     0.3
OllamaChat.RAGSimilarityThreshold = 0.3



# OllamaChat.RAGPromptTemplate
#     Description: Template for including RAG information in bot prompts.
#     Placeholders (named): {rag_info}
OllamaChat.RAGPromptTemplate = "RELEVANT INFORMATION:\n{rag_info}\nUse this information to provide accurate and detailed responses when applicable."


# OllamaChat.RAGExpandReferences
#     Description: When enabled, after retrieving the top matches, also pull in the entries they
#                  link to via their "references" field (one hop, deduped, capped). Rendered as a
#                  short "Related: <name>, <short description>" line appended to the RAG info.
#     Default:     1 (enabled)
OllamaChat.RAGExpandReferences = 1



# OllamaChat.RAGMaxReferences
#    Per-direct-hit max references (effective max = RAGMaxRetrievedItems x this).
#    Was a single global pool of 5; now per-hit (see RAGRandomizeReferences).
OllamaChat.RAGMaxReferences = 2

# OllamaChat.RAGRandomizeReferences
#    1 = per-direct-hit RANDOM reference sampling (variety, no global-pool crowding,
#        so a zone reliably surfaces varied dungeons via its reference graph);
#    0 = legacy global first-come-first-served pool (exact prior behavior).
OllamaChat.RAGRandomizeReferences = 1

# OllamaChat.RAGRandomizeSelection
#     Description: When enabled (1), direct-hit RAG snippets are sampled (weighted by similarity) from the
#                  top RAGSelectionPoolSize candidates instead of always taking the strict top RAGMaxRetrievedItems.
#                  Adds variety while staying on-topic. 0 = strict top-N (original).
#     Default:     1
OllamaChat.RAGRandomizeSelection = 1

# OllamaChat.RAGSelectionPoolSize
#     Description: Top-K candidate window the sampler draws RAGMaxRetrievedItems from (only when
#                  RAGRandomizeSelection = 1). Set equal to RAGMaxRetrievedItems to neutralize variety.
#     Default:     8
OllamaChat.RAGSelectionPoolSize = 8

#
#    OllamaChat.RAGImprovedScoring
#        Use IDF-weighted, stopword-filtered, stemmed scoring (1) or the legacy
#        raw term-frequency scoring (0). Default 1.
#
OllamaChat.RAGImprovedScoring = 1

#
#    OllamaChat.EnableRAGInitiated
#        Inject context-derived world knowledge into initiated/ambient bot chatter.
#        Default 1. (Requires OllamaChat.EnableRAG = 1.)
#
OllamaChat.EnableRAGInitiated = 1
#
#    OllamaChat.RAGInitiatedMaxItems
#        Max RAG entries injected per initiated message. Default 1 (small for token budget).
#
OllamaChat.RAGInitiatedMaxItems = 1
#
#    OllamaChat.EnableRAGReplyContext
#        Also pull a small number of locale/faction context entries on the reply path,
#        merged with the player-message results. Default 1. (Requires OllamaChat.EnableRAG = 1.)
#
OllamaChat.EnableRAGReplyContext = 1
#
#    OllamaChat.RAGReplyContextItems
#        Max extra context entries appended to reply-path retrieval. Default 1.
#
OllamaChat.RAGReplyContextItems = 1

# --------------------------------------------
# EMOTE-AUGMENTED CHAT
# --------------------------------------------

#
#    OllamaChat.EmoteChat.Enable
#        Let bots prefix a chat line with ONE [emote] tag the module performs as a visual gesture.
#        Default: 1 (enabled)
#
OllamaChat.EmoteChat.Enable = 1

#
#    OllamaChat.EmoteChat.Vocabulary
#        Pipe-separated list of allowed emote names (empty = all built-in). e.g. "wave|laugh|cheer"
#        Built-in: wave laugh cheer cry point bow flex applaud roar no yes shrug salute kneel beg talk rude
#        Default: (empty)
#
OllamaChat.EmoteChat.Vocabulary =

#
#    OllamaChat.EmoteChat.InstructionTemplate
#        Prompt instruction appended to generated chat. {emote_list} expands to the allowed [tag] list.
#
OllamaChat.EmoteChat.InstructionTemplate = "Always speak in words - never reply with only an emote. You may prefix your spoken line with ONE emote in square brackets from this list if it truly fits, then say your line. Allowed: {emote_list}. Example: [cheer] We did it!"

# OllamaChat.EmoteActionRouting
#     When enabled (1), a bracketed segment becomes an action instead of being spoken verbatim:
#     a curated emote (exact or a fuzzy-matched inflection like [Waving]) performs the gesture;
#     a freeform/unmatched bracket (e.g. [smoke blows out slowly]) renders as a /me text-emote in
#     Say/Yell, or as *action* text in Guild/Party/Raid/General. When disabled (0), only exact curated
#     emotes perform; unknown brackets are spoken verbatim (legacy).
#     Default: 1
OllamaChat.EmoteActionRouting = 1

# --------------------------------------------
# WORLD-NPC PROXIMITY CHAT (P1: ROLE BARKS)
# --------------------------------------------

# OllamaChat.WorldNpcChatEnable
#     Description: When enabled (1), friendly service NPCs occasionally greet a nearby player
#                  with a role-appropriate line (innkeeper/vendor/questgiver/etc). GPU-free.
#     Default:     1 (true)
OllamaChat.WorldNpcChatEnable = 1

# OllamaChat.WorldNpcChatTickMs   - scan cadence in ms. Default 5000.
OllamaChat.WorldNpcChatTickMs = 5000
# OllamaChat.WorldNpcChatRange   - greet radius in yards. Default 15.
OllamaChat.WorldNpcChatRange = 15
# OllamaChat.WorldNpcChatNpcCooldownSec - per-NPC quiet period. Default 120.
OllamaChat.WorldNpcChatNpcCooldownSec = 120
# OllamaChat.WorldNpcChatPlayerCooldownSec - per-player quiet period. Default 20.
OllamaChat.WorldNpcChatPlayerCooldownSec = 20
# OllamaChat.WorldNpcChatMaxPerTick - max NPCs that greet one player per tick. Default 1.
OllamaChat.WorldNpcChatMaxPerTick = 1

# Per-role phrase pools (| separated). An empty pool disables that role.
# Placeholders: {name} {race} {class} {zone} {player}
OllamaChat.WorldNpcInnkeeperPhrases = Rest your feet, {race} - a warm bed and a hot meal await.|Welcome, traveler. The fire's lit and the ale's cold.|A room's always ready for a weary {race}, friend.|You look road-worn, {class}. Sit, eat, and stay a while.|Mind the hearth, traveler - finest rest in all {zone}.|Hungry, {race}? The stew's hot and the beds are soft.
OllamaChat.WorldNpcVendorPhrases = Finest wares in {zone}, {race}. Care to browse?|Coin for goods, {race} - what'll it be?|Goods aplenty, {race} - take a look at my stock.|A discerning {class} knows quality when they see it.|Fresh stock today, traveler. What catches your eye?|Step up, {race} - best goods this side of {zone}.
OllamaChat.WorldNpcQuestgiverPhrases = You there, {race}! I've work that needs doing.|A capable {class}, just what I need. Have a moment?|Ah, a {class}! Perhaps you can lend me a hand.|You look capable, {race}. There's a task at hand.|Stranger! There's trouble hereabouts - have you a moment?|Just the {race} I was hoping to see. Care to help?
OllamaChat.WorldNpcQuestTurninPhrases = You've returned, {race}! Let's see what you've brought me.|Back at last - I trust the task is done?|Well done, {race}! I knew I could count on you.|You've come through, {class}. Let me see the results.|Returned in one piece! Show me what you found.|Good to see you back, {race}. The deed is done, I hope?
OllamaChat.WorldNpcFlightmasterPhrases = Need wings, {race}? My gryphons are rested and ready.|Where to, traveler? The skies over {zone} are clear.|Off to distant lands, {race}? My beasts are ready.|A {class} in a hurry? I'll get you there swiftly.|Fair skies over {zone} today - where shall I send you?|Need to travel, traveler? Climb aboard.
OllamaChat.WorldNpcTrainerPhrases = Sharpen your craft, {class}. I've much to teach.|A {class} should never stop learning, {race}.|There's always more to learn, {race}. Shall we begin?|A skilled {class} is a force to behold. Train with me.|Hone your talents here, {race} - I'll show you how.|Discipline makes the {class}, friend. Ready to study?
OllamaChat.WorldNpcBankerPhrases = Your valuables are safe with us, {race}.|Need to stow your gold? Step right up.|Your gold rests secure in our vaults, {race}.|Storing your treasures, {class}? Right this way.|We guard your valuables well, traveler.|Deposits or withdrawals, {race}? All handled here.

# OllamaChat.WorldNpcCharactersEnable
#     Description: When enabled (1), curated 'character' NPCs (mod_ollama_chat_npc table) speak
#                  LLM-generated in-character lines when a player nears them (Tier 1). Requires
#                  WorldNpcChatEnable. Disabled (0) -> those NPCs fall back to Tier-2 role barks.
#     Default:     1 (true)
OllamaChat.WorldNpcCharactersEnable = 1

# OllamaChat.WorldNpcCharacterCooldownSec - default per-character quiet period (table cooldown_sec overrides). Default 300.
OllamaChat.WorldNpcCharacterCooldownSec = 300
# OllamaChat.WorldNpcCharacterCallsPerMin - global cap on character LLM calls per minute (shares the GPU with bot chat). Default 6.
OllamaChat.WorldNpcCharacterCallsPerMin = 6

# OllamaChat.WorldNpcCharacterPrompt - persona prompt. Placeholders: {name} {title} {zone} {visitor}
OllamaChat.WorldNpcCharacterPrompt = You are {name}, {title}. {visitor} has approached you in {zone}. Greet or address them directly in one or two short sentences, in your own voice and station. Stay fully in character; never mention being an NPC or a game.
